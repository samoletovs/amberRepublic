  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "refresh-data": "node scripts/refresh-data/refresh.mjs",
    "refresh-data:dry": "node scripts/refresh-data/refresh.mjs --dry-run",
    "refresh-data:petitions": "node scripts/refresh-data/refresh.mjs --source petitions"
  },
  "keywords": [
    "game",
    "simulation",
    "latvia",
    "politics"
  ],
  "author": "Sam",
