# ──────────────────────────────────────────────────────────────────────
# amberRepublic Environment Variables
#
# Copy to .env for local development.
# In production, API env vars are set via Azure SWA App Settings.
# ──────────────────────────────────────────────────────────────────────

# ── AI Provider (Azure Functions API) ──
# The API functions use these for LLM-based event generation
AZURE_OPENAI_ENDPOINT=https://your-region.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Application Insights (optional) ──
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── API guardrails (public-repo abuse protection) ──
# See api/src/guardrails.js. Override in Azure SWA App Settings if needed.
RATE_LIMIT_PER_HOUR=30
DAILY_BUDGET_USD=1.00

# ── Telegram Notifications (track-login runtime only — family bot) ──
# Used by api/src/functions/track-login.js to record user sign-ins.
# For CI/CD deploy notifications the workflow uses org-level secrets
# NAURO_BOT_TOKEN + NAURO_CHAT_ID (new nauroLabs ops bot) — see PLATFORM.md §8.
TELEGRAM_NOTIFY_URL=
