# ──────────────────────────────────────────────────────────────────────
# amberRepublic Environment Variables
#
# Copy to .env for local development.
# In production, API env vars are set via Azure SWA App Settings.
# ──────────────────────────────────────────────────────────────────────

# ── AI Provider (Azure Functions API) ──
# The API functions use these for LLM-based event generation
AZURE_OPENAI_ENDPOINT=https://your-region.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Application Insights (optional) ──
APPLICATIONINSIGHTS_CONNECTION_STRING=
